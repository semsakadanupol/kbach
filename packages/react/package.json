{
  "name": "@kbach/react",
  "version": "0.5.60",
  "description": "React / React Native components and hooks for the Kbach framework",
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "source": "./src/jsx-runtime.tsx",
      "import": "./dist/jsx-runtime.mjs",
      "require": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "source": "./src/jsx-dev-runtime.tsx",
      "import": "./dist/jsx-dev-runtime.mjs",
      "require": "./dist/jsx-dev-runtime.js"
    },
    "./types": {
      "types": "./types.d.ts"
    },
    "./vite": {
      "types": "./dist/vite-plugin.d.ts",
      "source": "./src/vite-plugin.ts",
      "import": "./dist/vite-plugin.mjs",
      "require": "./dist/vite-plugin.js"
    },
    "./vite/client": {
      "types": "./dist/vite-plugin-client.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/jsx-runtime.tsx src/jsx-dev-runtime.tsx src/vite-plugin.ts --format esm,cjs --dts --clean --external vite",
    "postbuild": "node -e \"const f=require('fs');f.copyFileSync('src/vite-plugin-client.d.ts','dist/vite-plugin-client.d.ts');f.copyFileSync('src/vite-plugin-client.d.ts','dist/vite-plugin-client.d.mts')\"",
    "dev": "tsup src/index.ts src/jsx-runtime.tsx src/jsx-dev-runtime.tsx src/vite-plugin.ts --format esm,cjs --dts --watch --external vite",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "postinstall": "node scripts/postinstall.js"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/react": "^19.2.0",
    "tsup": "^8.0.0",
    "vite": "^5.4.21",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "scripts",
    "types.d.ts",
    "jsx-runtime.js",
    "jsx-dev-runtime.js",
    "kbach-react.md",
    "README.md"
  ]
}
