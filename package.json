{
  "name": "kbach",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && node -e \"require('fs').rmSync('node_modules',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.0",
    "turbo": "^2.0.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
